        ELSE CAST(milliseconds AS INT)
    END AS race_time_ms,

    fastestlap,

    CASE 
        WHEN fastestlaptime = '\\N' THEN NULL
        ELSE fastestlaptime
    END AS fastest_lap_time,

    statusid AS status_id

FROM F1_DB.RAW.sprint_results
  )
