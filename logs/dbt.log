    as (

select
    r.resultid as result_id,

    r.raceid as race_id,
    rc.season_year,
    rc.circuit_id,
    rc.race_date,

    r.driverid as driver_id,
    r.constructorid as constructor_id,

    r.grid as start_position,
    r.positionorder as finish_position,

    case
        when r.positionorder = 1 then 25
        when r.positionorder = 2 then 18
        when r.positionorder = 3 then 15
        when r.positionorder = 4 then 12
        when r.positionorder = 5 then 10
        when r.positionorder = 6 then 8
        when r.positionorder = 7 then 6
        when r.positionorder = 8 then 4
        when r.positionorder = 9 then 2
        when r.positionorder = 10 then 1
        else 0
    end as points,

    r.laps,


    nullif(r.time, '\\N') as race_time,

    case 
        when r.milliseconds = '\\N' then null
        else cast(r.milliseconds as int)
    end as race_time_ms,

    r.fastestlap as fastest_lap,
    nullif(r.fastestlaptime, '\\N') as fastest_lap_time,


    r.statusid as status_id,
    s.status as race_status,


    case 
        when lower(s.status) like '%finished%' then 0
        else 1
    end as dnf_flag,

    case
        when r.positionorder = 1 then 'Winner'
        when r.positionorder <= 3 then 'Podium'
        when r.positionorder <= 10 then 'Points'
        else 'Others'
    end as position_group,

    (r.grid - r.positionorder) as positions_gained

from F1_DB.RAW.results r

left join F1_DB.ANALYTICS.stg_races rc
    on r.raceid = rc.race_id

left join F1_DB.ANALYTICS.stg_status s
    on r.statusid = s.status_id
    )

