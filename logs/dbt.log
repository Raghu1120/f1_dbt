        WHEN positionorder = 3 THEN 6
        WHEN positionorder = 4 THEN 5
        WHEN positionorder = 5 THEN 4
        WHEN positionorder = 6 THEN 3
        WHEN positionorder = 7 THEN 2
        WHEN positionorder = 8 THEN 1
        ELSE 0
    END AS points,

    laps,

    CASE 
        WHEN time = '\\N' THEN NULL
